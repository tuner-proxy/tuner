{
  "name": "@tuner-proxy/core",
  "version": "0.6.1",
  "description": "A programmable debugging proxy",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tuner-proxy/tuner.git",
    "directory": "packages/core"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./cli": {
      "types": "./dist/cli/cli.d.mts",
      "default": "./dist/cli.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "tuner": "./bin/cli.mjs"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "event-to-promise": "^0.8.0",
    "ip-matching": "^2.1.2",
    "lodash.flatmap": "^4.5.0",
    "lodash.flatten": "^4.4.0",
    "lru-cache": "^11.2.7",
    "node-forge": "^1.3.3",
    "pac-resolver": "^8.0.0",
    "quickjs-emscripten": "^0.32.0",
    "socks": "^2.8.7"
  },
  "devDependencies": {
    "@tsconfig/node-lts": "^24.0.0",
    "@types/event-to-promise": "^0.7.5",
    "@types/lodash.flatmap": "^4.5.9",
    "@types/lodash.flatten": "^4.4.9",
    "@types/node": "^25.5.0",
    "@types/node-forge": "^1.3.14",
    "@typescript/native-preview": "7.0.0-dev.20260317.1",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
